---
import type { CollectionEntry } from "astro:content";
import Link from "@components/Link.astro";

type Props = {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { title, description, role, years, tags, links } = project.data;
---

<div class="group p-4 rounded-lg border border-black/15 dark:border-white/20 hover:bg-black/5 dark:hover:bg-white/5 transition-colors duration-300">
  <div class="flex flex-col gap-2">
    <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
      <h3 class="font-semibold text-black dark:text-white">
        {title}
      </h3>
      <span class="text-sm text-black/60 dark:text-white/60">
        {years}
      </span>
    </div>

    <p class="text-sm text-black/80 dark:text-white/80">
      {description}
    </p>

    <div class="text-sm text-black/60 dark:text-white/60">
      {role}
    </div>

    <div class="flex flex-wrap gap-1.5 mt-1">
      {tags.slice(0, 5).map((tag) => (
        <span class="px-2 py-0.5 text-xs rounded-full bg-black/5 dark:bg-white/10 text-black/70 dark:text-white/70">
          {tag}
        </span>
      ))}
      {tags.length > 5 && (
        <span class="px-2 py-0.5 text-xs rounded-full bg-black/5 dark:bg-white/10 text-black/70 dark:text-white/70">
          +{tags.length - 5}
        </span>
      )}
    </div>

    {links && links.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-2">
        {links.map((link) => (
          <Link href={link.url} external>
            {link.label}
          </Link>
        ))}
      </div>
    )}
  </div>
</div>
